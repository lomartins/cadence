# Cadence — Spotify app configuration (for local development / contributors)
#
# In normal use you set these through the Claude Code plugin config prompt
# (spotify_client_id, market, ...). This file is only for running the server
# directly with `npm run dev`.

# Your Spotify app Client ID from https://developer.spotify.com/dashboard
# In the dashboard, add this exact Redirect URI:   http://127.0.0.1:8888/callback
#   - use the 127.0.0.1 loopback IPv4 literal — "localhost" is NOT allowed
#   - http (not https) is fine because it's loopback
#   - if 8888 is busy, set CADENCE_AUTH_PORT below and register the matching port
# The app OWNER must have an active Spotify Premium subscription (2026 dev-mode
# requirement), and a dev-mode app is capped at 5 users.
CADENCE_CLIENT_ID=

# ISO 3166-1 alpha-2 market, e.g. US, GB, BR (dev-mode /me no longer returns country)
CADENCE_MARKET=US

# Optional defaults
CADENCE_DEFAULT_VIBE=deep-focus
CADENCE_AUTO_SWITCH=true
CADENCE_LOCAL_FALLBACK=true
CADENCE_AUTH_PORT=8888

# Where state is stored when running standalone (the plugin sets this to its data dir)
# CADENCE_DATA_DIR=~/.config/cadence
